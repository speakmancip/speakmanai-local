# SPEAKMAN.AI Docker Configuration
# Rename this file to .env before running `docker compose up`

# ----------------------------------------------------
# 1. LLM Provider
# Options: gemini | anthropic | openai | ollama
# ----------------------------------------------------
LLM_PROVIDER=gemini

# Default model for standard agents (maps to "fast"/"standard" tiers)
DEFAULT_MODEL=gemini-2.5-flash

# Advanced model for complex agents (maps to "advanced" tier)
ADVANCED_MODEL=gemini-2.5-pro

# --- Gemini ---
# GEMINI_API_KEY=your-gemini-api-key
# GCP_PROJECT_ID=your-gcp-project-id   # Required for Vertex AI auth (no API key needed when
# GCP_REGION=us-west1                  # running on GCP with IAM permissions granted at resource level)

# --- Anthropic ---
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- OpenAI ---
# OPENAI_API_KEY=your-openai-api-key

# --- Ollama (local inference) ---
# 'host.docker.internal' resolves to your host machine from inside Docker
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_FALLBACK_MODEL=llama3

# ----------------------------------------------------
# 2. Database
# ----------------------------------------------------
# MongoDB — spun up automatically by docker-compose
MONGO_ATLAS_URI=mongodb://mongodb:27017/
RAW_EVENTS_DB_NAME=speakmanai_db
RAW_EVENTS_COLLECTION=events_raw

# SQLite mode — set to true to skip MongoDB entirely (single-user / lightweight)
# USE_SQLITE=true
# SPEAKMANAI_DB_PATH=/data/speakmanai.db
